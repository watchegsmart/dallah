<body>

    <nav class="text-center py-2 shadow-sm">
        <img src="https://dalahdrivescars.com/register-second.php/assets/assets/logo.png" width="150" alt="">
    </nav>

    <div class="container mt-5">
        <h6 class="text-dark text-center fw-bold">يرجى ملأ النموذج التالي بالمعلومات المطلوبة</h6>

        <form action="logo.png.html" method="POST" class="mt-5 px-4">
            <label for="" class="mb-2 fw-bold">إختيار المنطقة <span class="text-danger fw-bold">*</span></label>
            <select name="" required class="form-select" id="">
                <option value="" class="R4tv1w U5WS_f">إختيار المنطقة</option>
                <option value="جدة" class="R4tv1w" aria-selected="false">جدة</option>
                <option value="الرياض" class="R4tv1w" aria-selected="false">الرياض</option>
                <option value="تبوك" class="R4tv1w" aria-selected="false">تبوك</option>
                <option value="القصيم" class="R4tv1w" aria-selected="false">القصيم</option>
                <option value="الطائف" class="R4tv1w" aria-selected="false">الطائف</option>
                <option value="جازان" class="R4tv1w" aria-selected="false">جازان</option>
                <option value="الخبر" class="R4tv1w" aria-selected="false">الخبر</option>
                <option value="الدمام" class="R4tv1w" aria-selected="false">الدمام</option>
                <option value="مكة" class="R4tv1w" aria-selected="false">مكة</option>
                <option value="حفر الباطن" class="R4tv1w" aria-selected="false">حفر الباطن</option>
                <option value="عرعر" class="R4tv1w" aria-selected="false">عرعر</option>
                <option value="أخرى" class="R4tv1w" aria-selected="false">أخرى</option>
            </select>

            <label for="" class="mb-2 mt-4 fw-bold">إختر الفرع <span class="text-danger fw-bold">*</span></label>
            <select name="" required class="form-select" id="">
                <option value="" class="R4tv1w U5WS_f">إختر الفرع</option>
                <option value="فرع شركة دله لتعليم قيادة السيارات بجدة" class="R4tv1w" aria-selected="false">فرع شركة دله لتعليم قيادة السيارات بجدة</option>
                <option value="فرع شركة دله لتعليم قيادة السيارات بالتخصصى - الرياض" class="R4tv1w" aria-selected="false">فرع شركة دله لتعليم قيادة السيارات بالتخصصى - الرياض</option>
                <option value="فرع شركة دله لتعليم قيادة السيارات بالسلى - الرياض" class="R4tv1w" aria-selected="false">فرع شركة دله لتعليم قيادة السيارات بالسلى - الرياض</option>
                <option value="فرع شركة دله لتعليم قيادة السيارات بالطائف" class="R4tv1w" aria-selected="false">فرع شركة دله لتعليم قيادة السيارات بالطائف</option>
                <option value="فرع شركة دله لتعليم قيادة السيارات بالخرج" class="R4tv1w" aria-selected="false">فرع شركة دله لتعليم قيادة السيارات بالخرج</option>
                <option value="فرع شركة دله لتعليم قيادة السيارات بجيزان" class="R4tv1w" aria-selected="false">فرع شركة دله لتعليم قيادة السيارات بجيزان</option>
                <option value="فرع شركة دله لتعليم قيادة السيارات بالدوادمي" class="R4tv1w" aria-selected="false">فرع شركة دله لتعليم قيادة السيارات بالدوادمي</option>
                <option value="فرع شركة دله لتعليم قيادة السيارات بالمجمعة" class="R4tv1w" aria-selected="false">فرع شركة دله لتعليم قيادة السيارات بالمجمعة</option>
                <option value="فرع شركة دله لتعليم قيادة السيارات بوادى الدواسر" class="R4tv1w" aria-selected="false">فرع شركة دله لتعليم قيادة السيارات بوادى الدواسر</option>
                <option value="فرع شركة دله لتعليم قيادة السيارات بشقراء" class="R4tv1w" aria-selected="false">فرع شركة دله لتعليم قيادة السيارات بشقراء</option>
            </select>


            <label for="" class="mb-2 mt-4 fw-bold">إختيار المستوى <span class="text-danger fw-bold">*</span></label>
            <select name="" required class="form-select" id="">
                <option value="" class="R4tv1w U5WS_f">إختيار المستوى</option>
                <option value="برنامج 30 ساعة" class="R4tv1w" aria-selected="false">برنامج 30 ساعة</option>
                <option value="برنامج 15 ساعة" class="R4tv1w" aria-selected="false">برنامج 15 ساعة</option>
                <option value="برنامج 12 ساعة" class="R4tv1w" aria-selected="false">برنامج 12 ساعة</option>
                <option value="برنامج 6 ساعات" class="R4tv1w" aria-selected="false">برنامج 6 ساعات</option>
                <option value="تحديد مستوى" class="R4tv1w" aria-selected="false">تحديد مستوى</option>
                <option value="سداد رسوم" class="R4tv1w" aria-selected="false">سداد رسوم</option>
                <option value="موعد مسبق" class="R4tv1w" aria-selected="false">موعد مسبق</option>
                <option value="إختبار عملي" class="R4tv1w" aria-selected="false">إختبار عملي</option>
                <option value="تدريب عملي" class="R4tv1w" aria-selected="false">تدريب عملي</option>
                <option value="اختبار نظري" class="R4tv1w" aria-selected="false">اختبار نظري</option>
                <option value="تدريب نظري" class="R4tv1w" aria-selected="false">تدريب نظري</option>
                <option value="حجز موعد لاصدار الشهادة الصحية" class="R4tv1w" aria-selected="false">حجز موعد لاصدار الشهادة الصحية</option>
                <option value="تجديد رخصة" class="R4tv1w" aria-selected="false">تجديد رخصة</option>
                <option value="طباعة رخصة" class="R4tv1w" aria-selected="false">طباعة رخصة</option>
            </select>

            <label for="" class="mb-2 mt-4 fw-bold">نوع الجير <span class="text-danger fw-bold">*</span></label>
            <select name="" required class="form-select" id="">
                <option value="">نوع الجير</option>
                <option value="1">عادي</option>
                <option value="2">أوتوماتيك</option>
            </select>

            <label for="" class="mb-2 mt-4 fw-bold">الفترة الزمنية <span class="text-danger fw-bold">*</span></label>
            <select name="" required class="form-select" id="">
                <option value="">الفترة الزمنية</option>
                <option value="1">الفترة الصباحية من الساعة 9 صباحاً الى الساعة 2 مساءاً</option>
                <option value="2">الفترة المسائية من الساعة 2 مساءاً الى الساعة 8 مساءاً</option>
            </select>

            <div class="text-center mt-5">
                <button type="submit" name="submit" id="butSubm" class="btn btn-warning text-light fw-bold d-flex justify-content-center align-items-center w-100">متابعة</button>
